#include <iostream>
using namespace std;

int A[3], B[3], C[3];
int topA = 0, topB = 0, topC = 0;

void pushA(int x) {
	A[topA++] = x;
}
void pushB(int x) {
	B[topB++] = x;
}
void pushC(int x) {
	C[topC++] = x;
}

int popA() {
	return A[--topA];
}
int popB() {
	return B[--topB];
}
int popC() {
	return C[--topC];
}

void tampil() {
	cout << "\nA: ";
	for(int i=0; i<topA; i++) cout << A[i] << " ";

	cout << "\nB: ";
	for(int i=0; i<topB; i++) cout << B[i] << " ";

	cout << "\nC: ";
	for(int i=0; i<topC; i++) cout << C[i] << " ";
	cout << "\n---------------------------------\n";
}

int main() {
	cout << "====== MENARA HANOI(STACK) ======\n";

	// isi awal (besar ke kecil)
	pushA(30);
	pushA(20);
	pushA(10);

	tampil();

	// langkah sesuai soal
	pushC(popA());
	cout << "Langkah 1: Pindah 10 dari A ke C\n";
	tampil();

	pushB(popA());
	cout << "Langkah 2: Pindah 20 dari A ke B\n";
	tampil();

	pushB(popC());
	cout << "Langkah 3: Pindah 10 dari C ke B\n";
	tampil();

	pushC(popA());
	cout << "Langkah 4: Pindah 30 dari A ke C\n";
	tampil();

	pushA(popB());
	cout << "Langkah 5: Pindah 10 dari B ke A\n";
	tampil();

	pushC(popB());
	cout << "Langkah 6: Pindah 20 dari B ke C\n";
	tampil();

	pushC(popA());
	cout << "Langkah 7: Pindah 10 dari A ke C\n";
	tampil();

	return 0;
}
